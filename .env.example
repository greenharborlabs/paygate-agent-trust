# Local Paygate Agent Trust environment.
# Copy this file to .env and replace placeholders with local values.
# .env is ignored by git. Do not commit real LNbits keys or secrets.

# Enables Paygate payment enforcement for the paid report endpoint.
# Use false for no-payment local smoke tests; use true for real LNbits testing.
PAYGATE_ENABLED=false

# Selects the Lightning backend implementation. Use lnbits for real-sats testing.
PAYGATE_BACKEND=lnbits

# Root URL of your LNbits SaaS instance, without an /api suffix.
# If payee_wallet and payer_wallet are in the same LNbits instance, this matches PAYER_LNBITS_URL.
PAYGATE_LNBITS_URL="https://<your-lnbits-instance>"

# From payee_wallet: invoice/read key used by this app to create invoices and check payment status.
# Do not use the payer wallet key here.
PAYGATE_LNBITS_API_KEY="<payee-wallet-api-key>"

# Stable random secret used to bind MPP payment challenges to the request.
# Generate with: openssl rand -base64 32
# Keep stable during a test run; changing it invalidates outstanding challenges.
PAYGATE_PROTOCOLS_MPP_CHALLENGE_BINDING_SECRET="<random-secret-at-least-32-bytes>"

# Timeout budget for LNbits calls made by the Paygate starter.
# Increase for SaaS instances that are slow on first request or cold network paths.
PAYGATE_LIGHTNING_TIMEOUT_SECONDS=20
PAYGATE_LNBITS_REQUEST_TIMEOUT_SECONDS=20
PAYGATE_LNBITS_CONNECT_TIMEOUT_SECONDS=10

# Used by scripts/paygate-lnbits-real-sats-test.sh as the client/agent payer wallet.
# Root URL of the LNbits instance that contains payer_wallet.
# Usually the same value as PAYGATE_LNBITS_URL for local testing.
PAYER_LNBITS_URL="https://<your-lnbits-instance>"

# From payer_wallet: admin key used by the test script to pay invoices programmatically.
# This wallet must have sats. You can fund it by creating a receive invoice in LNbits and paying it from Muun.
PAYER_LNBITS_ADMIN_KEY="<payer-wallet-admin-key>"

# Alternative programmable payer backend: Voltage/LND.
# Use this when the LNbits payer wallet does not expose payment preimages.
# Voltage REST URLs usually look like: https://<node-name>.m.voltageapp.io:8080
PAYER_LND_REST_URL="https://<voltage-lnd-rest-endpoint>:8080"

# Macaroon credential for the LND payer node, encoded as hex.
# For testing, an admin macaroon works. Later prefer a narrow macaroon with payment permissions.
# Convert a macaroon file with: xxd -p -c 256 admin.macaroon
PAYER_LND_MACAROON_HEX="<lnd-macaroon-hex>"

# Optional. Voltage commonly uses public CA TLS, so leave unset unless TLS verification fails.
# PAYER_LND_TLS_CERT_PATH="/absolute/path/to/tls.cert"

# Optional local defaults.
# Base URL used by helper scripts to call this app.
PAYGATE_BASE_URL=http://localhost:8080

# General base URL used by README curl examples.
BASE_URL=http://localhost:8080

# Local report signing key id published in reports and catalog.
# scripts/local-dev-env.sh generates local signing keys automatically unless REPORT_SIGNING_* is already set.
REPORT_SIGNING_KEY_ID=local-dev
